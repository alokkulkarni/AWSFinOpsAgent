# Copy to .env (git-ignored). NEVER commit real secrets.

# --- Auth mode: profile | env | assume_role ---
FINOPS_AWS_AUTH=profile

# profile mode — prefer a dedicated read-only profile over root.
# Create one with: ./scripts/setup_finops_iam.sh   (see docs/IAM.md)
AWS_PROFILE=default
# AWS_PROFILE=finops

# region (none was set in your shell — set it explicitly)
AWS_REGION=us-east-1
FINOPS_CE_REGION=us-east-1

# env mode (uncomment to use static keys instead of a profile)
# FINOPS_AWS_AUTH=env
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# assume_role mode (best for org / multi-account)
# FINOPS_AWS_AUTH=assume_role
# FINOPS_ASSUME_BASE=env                 # base creds for the assume: env | profile
# FINOPS_ROLE_ARN=arn:aws:iam::<account-id>:role/FinOpsReadOnly
# FINOPS_EXTERNAL_ID=

# --- Agent behaviour ---
# Sets the DEFAULT action mode. You can also switch it at runtime in the dashboard sidebar
# (no restart) — advisory: read-only · artifacts: generate fix scripts · guarded_write: apply.
FINOPS_MODE=advisory                     # advisory | artifacts | guarded_write
FINOPS_ORG_MODE=false

# --- Observability (OpenTelemetry: traces, metrics, logs) — ON by default ---
# With no collector endpoint, long-running servers print telemetry to the console; one-shot CLI
# commands stay quiet. The docker-compose observability overlay sets the endpoint automatically.
# FINOPS_TELEMETRY=true                   # master switch (false disables all export)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317   # standard OTEL var (or FINOPS_TELEMETRY_ENDPOINT)
# FINOPS_TELEMETRY_EXPORTER=auto          # auto | otlp | console | none
# FINOPS_TELEMETRY_PROTOCOL=grpc          # grpc | http
# FINOPS_TELEMETRY_SAMPLE_RATIO=1.0       # trace head-sampling (0..1); lower = less volume
# Privacy: how prompt/response/tool content is handled in traces (account ids/ARNs/emails are
# ALWAYS redacted in omit/redact). omit = drop content events; redact = keep but scrub; full = keep.
# FINOPS_TELEMETRY_CONTENT=omit           # omit | redact | full

# --- Conversation memory & summarization (FinOps + DevSecOps agents; both ON by default) ---
# Summarization folds old turns into a compact summary (instead of dropping them) so the chat
# context never grows unbounded — automatic, inside the event loop, never interrupts the chat.
# FINOPS_CONVERSATION_SUMMARIZE=true      # set false to use Strands' default sliding window
# FINOPS_CONVERSATION_PRESERVE_RECENT=10  # most-recent turns kept verbatim
# FINOPS_SUMMARIZER_ROLE=digest           # model role used to summarize (blank = the agent's model)
# Persistent memory remembers durable "important aspects" (goals, account/resource facts,
# decisions) and recalls them in future prompts. Stored locally; account IDs redacted on write.
# FINOPS_MEMORY=true                       # set false to disable recall + capture
# FINOPS_MEMORY_DIR=~/.finops_agent/memory # where memory is persisted (keep OUTSIDE the repo)

# --- LLM (Bedrock) ---
FINOPS_LLM_PROVIDER=bedrock              # bedrock | anthropic
FINOPS_LLM_REGION=us-east-1
# FINOPS_MODEL_ORCHESTRATOR=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# FINOPS_MODEL_DIGEST=us.amazon.nova-pro-v1:0
# Bedrock tuning (defaults in config/models.yaml):
# FINOPS_LLM_MAX_TOKENS=2048             # explicit max output tokens (avoids quota over-reserve)
# FINOPS_LLM_TEMPERATURE=0               # 0 = deterministic number relay
# FINOPS_LLM_CACHE=true                  # Bedrock prompt caching (system prompt + tools)
# Bedrock Guardrail (optional; off by default) — see docs/GUARDRAILS.md
# FINOPS_GUARDRAIL_ID=
# FINOPS_GUARDRAIL_VERSION=DRAFT

# Anthropic-API mode (only when FINOPS_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
